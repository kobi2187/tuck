import http

type Feed = {episodes: int}

pending:
  fn parse({body: str}) -> {feed: Feed}

task fetchFeed({url: str}) -> !{feed: Feed} [io]:
  let resp = {url} http::get   # [io] → compiler inserts yield here automatically
  if resp.ok:
    return {body: resp.value.body} parse
  err resp.err                 # re-raise: same code, this fn's result type
