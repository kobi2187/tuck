# Systems & Embedded MP3 Player Example
# Demonstrates hardware registers, events, tasks, actors, and memory pools.

distinct Hz = u32
distinct Milliseconds = u32

# 1. Global Event Registry
registry SystemEvents:
  | PlaybackStarted
  | PlaybackStopped
  | HardwareError({code: u8})

# 2. Hardware Register Mapping (MMIO)
register DAC_CR at 0x40007400:
  EN: bit 0 [read, write]
  BOFF: bit 1 [read, write]

register DMA1_CH3 at 0x40020030:
  EN: bit 0 [read, write]
  TCIE: bit 1 [read, write]

# 3. Sealed Lifecycle State Machine
type PlayerState [sealed]:
  | Idle
  | Decoding({sampleRate: Hz})
  | Paused
  transitions:
    Idle -> Decoding
    Decoding -> Paused
    Paused -> Decoding
    Decoding -> Idle
    Paused -> Idle

# 4. Static Zero-Allocation Memory Pool
pool BufferPool: Array[512, u8] * 4

# 5. Type Invariant
type Volume:
  level: u8
  invariant:
    level <= 100

# 6. Cooperative StreamReader Task
task streamReader({streamId: u8, chunks: Seq[u32]}) -> !void [io]:
  for i in chunks:
    let buf = BufferPool.acquire or return
    # Implicitly yields control back to scheduler while waiting on DMA read
    # buf.data = dmaRead {streamId}
    DMA1_CH3 ..EN {true}
    buf.release

# 7. Isolated Decoder Actor
actor Decoder [queue: 8]:
  state: PlayerState = PlayerState.Idle
  vol: Volume = Volume {level: 80}

  on play({rate: Hz}) -> void:
    # spec 4.4b: reassignment IS the transition — statically checked.
    # A message can arrive in any state, so match narrows first; only
    # states with a declared edge to Decoding may move there.
    match state:
      Idle: state = {sampleRate: rate} PlayerState.Decoding
      Paused: state = {sampleRate: rate} PlayerState.Decoding
      Decoding: ...
    SystemEvents.raise PlaybackStarted
    DAC_CR ..EN {true}

  on pause() -> void:
    match state:
      Decoding: state = PlayerState.Paused
      Idle: ...
      Paused: ...
    DAC_CR ..EN {false}

  on stop() -> void:
    # every state has a declared (or same-variant) edge to Idle:
    # no narrowing needed, the full set proves it
    state = PlayerState.Idle
    SystemEvents.raise PlaybackStopped
    DAC_CR ..EN {false}

static_assert sizeof(Volume) == 1

# 8. Main Application Controller
fn main() -> void:
  discard
