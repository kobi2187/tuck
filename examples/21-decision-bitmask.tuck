# Decision table over enumerable domains.
# The compiler proves completeness and reachability EXACTLY (no catch-all
# needed) and emits a single case over a packed integer key — no branch chains.

type Priority:
  | High
  | Low

decision route({priority: Priority, encrypted: bool}) -> int:
  | High  true  -> 1
  | High  false -> 2
  | Low   _     -> 3
